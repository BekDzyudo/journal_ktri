# Loyiha ildizida `.env` nomli fayl yarating (shu faylni nusxalash mumkin):
#   Windows PowerShell: Copy-Item .env.example .env

# API Base URL — oxirida /api bo'lishi kerak (login: .../api/auth/login/)
VITE_BASE_URL=https://journal.ktri.uz/api

# Mahalliy backend uchun:
# VITE_BASE_URL=http://localhost:8000/api

# Google bilan kirish (Google Cloud → OAuth 2.0 Client IDs → Web application)
VITE_GOOGLE_CLIENT_ID=721983807007-uau3csm99n60d39ppmr16f9pntlc1a2e.apps.googleusercontent.com

# Ixtiyoriy: VITE_BASE_URL bo'lmasa, origin + /api quriladi
# VITE_API_URL=https://journal.ktri.uz
